{
  "id": "streaks",
  "name": "Streaks",
  "version": "1.0.0",
  "description": "Track personal and family habits with streak counters. Create private or shared streaks, set up group challenges anyone can check off, and celebrate milestones together.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "family",
  "tags": ["habits", "wellness", "fitness", "goals", "streaks"],
  "data_access": {
    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "nav": {
    "label": "Streaks"
  },
  "storage": "db",
  "exports": ["member-streaks"],
  "publishes": ["streak.milestone"],
  "widget": { "label": "Streaks", "size": "small" },
  "resource_limits": { "max_db_bytes": 52428800 },
  "icon": "🔥",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["active_streaks", "todays_completions"]
  }
}
