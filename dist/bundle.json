{
  "manifest": {
    "id": "streaks",
    "name": "Streaks",
    "version": "1.0.0",
    "description": "Track personal and family habits with streak counters. Create private or shared streaks, set up group challenges anyone can check off, and celebrate milestones together.",
    "entrypoint": "index.html",
    "runtime": "static",
    "category": "family",
    "tags": [
      "habits",
      "wellness",
      "fitness",
      "goals",
      "streaks"
    ],
    "data_access": {
      "reads": [
        "family.members"
      ],
      "writes": []
    },
    "permissions": {
      "default_audience": "everyone",
      "requires_approval": false
    },
    "nav": {
      "label": "Streaks"
    },
    "storage": "db",
    "exports": [
      "member-streaks"
    ],
    "publishes": [
      "streak.milestone"
    ],
    "widget": {
      "label": "Streaks",
      "size": "small"
    },
    "resource_limits": {
      "max_db_bytes": 52428800
    },
    "icon": "🔥",
    "ai_access": {
      "allowed": true,
      "mode": "read_write",
      "db_exports": [
        "active_streaks",
        "todays_completions"
      ],
      "db_inserts": [
        "log_streak"
      ],
      "db_deletes": [
        "unlog_streak"
      ]
    }
  },
  "migrations": [
    {
      "version": 1,
      "sql": "CREATE TABLE IF NOT EXISTS streaks (\n  household_id UUID    NOT NULL DEFAULT current_setting('app.household_id', true)::uuid,\n  id           TEXT    NOT NULL,\n  owner_id     TEXT    NOT NULL,\n  title        TEXT    NOT NULL,\n  emoji        TEXT    NOT NULL DEFAULT '🔥',\n  -- 'private' = only owner sees it\n  -- 'adults'  = owner + all adults\n  -- 'everyone' = whole household\n  visibility   TEXT    NOT NULL DEFAULT 'private',\n  is_group     INTEGER NOT NULL DEFAULT 0,   -- 1 = any visible member can log\n  created_at   TEXT    NOT NULL,\n  archived_at  TEXT,\n  PRIMARY KEY (household_id, id)\n);\n\nCREATE TABLE IF NOT EXISTS streak_logs (\n  household_id UUID NOT NULL DEFAULT current_setting('app.household_id', true)::uuid,\n  id           TEXT NOT NULL,\n  streak_id    TEXT NOT NULL,\n  logged_by    TEXT NOT NULL,   -- member_id who checked it off\n  logged_date  TEXT NOT NULL,   -- YYYY-MM-DD local date\n  created_at   TEXT NOT NULL,\n  PRIMARY KEY (household_id, id)\n);\n\n-- Prevent duplicate logs for the same streak on the same day\nCREATE UNIQUE INDEX IF NOT EXISTS streak_logs_unique_day\n  ON streak_logs (household_id, streak_id, logged_date);"
    },
    {
      "version": 2,
      "sql": "-- Enforce streak visibility controls at the DB layer so children cannot see\n-- 'adults' or 'private' streaks by crafting direct SQL queries.\n--\n-- Children see: their own streaks (any visibility) OR streaks marked 'everyone'.\n-- Adults see: all streaks (unrestricted).\n-- streak_logs: children see only their own log entries.\n\nDROP POLICY IF EXISTS member_access ON streaks;\nCREATE POLICY member_access ON streaks\n  AS RESTRICTIVE FOR ALL TO hub_app_executor\n  USING (\n    current_setting('app.member_id', true) = ''\n    OR current_setting('app.member_role', true) != 'child'\n    OR owner_id = current_setting('app.member_id', true)\n    OR visibility = 'everyone'\n  );\n\nDROP POLICY IF EXISTS member_access ON streak_logs;\nCREATE POLICY member_access ON streak_logs\n  AS RESTRICTIVE FOR ALL TO hub_app_executor\n  USING (\n    current_setting('app.member_id', true) = ''\n    OR current_setting('app.member_role', true) != 'child'\n    OR logged_by = current_setting('app.member_id', true)\n  );"
    }
  ],
  "files": {
    "deletes/unlog_streak.sql": "DELETE FROM streak_logs\nWHERE streak_id    = $1\n  AND household_id = current_setting('app.household_id', true)::uuid\n  AND logged_date  = COALESCE($2, CURRENT_DATE::text)\n",
    "index.html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <base href=\"/run/streaks/\" />\n  <title>Streaks</title>\n  <style>\n    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n    body {\n      font-family: var(--hub-font, system-ui, sans-serif);\n      font-size: var(--hub-font-size, 15px);\n      background: var(--hub-bg, #f9fafb);\n      color: var(--hub-text, #111827);\n      min-height: 100vh;\n    }\n\n    .app-header {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      padding: 16px 20px 0;\n      gap: 12px;\n    }\n    .app-header h1 { font-size: 1.25rem; font-weight: 700; }\n\n    .tabs {\n      display: flex;\n      gap: 4px;\n      padding: 12px 20px 0;\n      border-bottom: 1px solid var(--hub-border, #e5e7eb);\n    }\n    .tab-btn {\n      padding: 8px 16px;\n      border: none;\n      background: none;\n      cursor: pointer;\n      font-size: 0.9rem;\n      color: var(--hub-text-muted, #6b7280);\n      border-bottom: 2px solid transparent;\n      margin-bottom: -1px;\n      font-family: inherit;\n      border-radius: var(--hub-radius, 6px) var(--hub-radius, 6px) 0 0;\n      transition: color .15s;\n    }\n    .tab-btn.active {\n      color: var(--hub-primary, #6366f1);\n      border-bottom-color: var(--hub-primary, #6366f1);\n      font-weight: 600;\n    }\n    .tab-btn:hover:not(.active) { color: var(--hub-text, #111827); }\n\n    .tab-panel { display: none; padding: 20px; }\n    .tab-panel.active { display: block; }\n\n    .section-actions {\n      display: flex;\n      justify-content: flex-end;\n      margin-bottom: 16px;\n    }\n\n    .streak-grid {\n      display: grid;\n      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));\n      gap: 14px;\n    }\n\n    .streak-card {\n      background: var(--hub-surface, #fff);\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 8px);\n      padding: 16px;\n      display: flex;\n      flex-direction: column;\n      gap: 10px;\n      position: relative;\n    }\n    .streak-card.logged { border-color: #22c55e; }\n\n    .streak-top {\n      display: flex;\n      align-items: flex-start;\n      gap: 10px;\n    }\n    .streak-emoji { font-size: 2rem; line-height: 1; flex-shrink: 0; }\n    .streak-info { flex: 1; min-width: 0; }\n    .streak-title { font-weight: 600; font-size: 1rem; word-break: break-word; }\n    .streak-owner { font-size: 0.8rem; color: var(--hub-text-muted, #6b7280); margin-top: 2px; }\n\n    .streak-counts {\n      display: flex;\n      gap: 16px;\n      align-items: center;\n    }\n    .count-block { text-align: center; }\n    .count-val { font-size: 1.6rem; font-weight: 700; line-height: 1; }\n    .count-label { font-size: 0.7rem; color: var(--hub-text-muted, #6b7280); text-transform: uppercase; letter-spacing: .04em; }\n    .count-fire { color: #f97316; }\n    .count-best { color: var(--hub-text-muted, #6b7280); }\n\n    .streak-badges {\n      display: flex;\n      gap: 6px;\n      flex-wrap: wrap;\n    }\n    .badge {\n      font-size: 0.72rem;\n      padding: 2px 7px;\n      border-radius: 99px;\n      border: 1px solid;\n      white-space: nowrap;\n    }\n    .badge-private  { color: #7c3aed; border-color: #ddd6fe; background: #f5f3ff; }\n    .badge-adults   { color: #b45309; border-color: #fde68a; background: #fffbeb; }\n    .badge-everyone { color: #047857; border-color: #a7f3d0; background: #ecfdf5; }\n    .badge-group    { color: #1d4ed8; border-color: #bfdbfe; background: #eff6ff; }\n\n    .streak-actions {\n      display: flex;\n      gap: 8px;\n      margin-top: 2px;\n    }\n\n    button { font-family: inherit; cursor: pointer; }\n\n    .btn {\n      padding: 7px 14px;\n      border-radius: var(--hub-radius, 6px);\n      border: 1px solid var(--hub-border, #e5e7eb);\n      background: var(--hub-surface, #fff);\n      color: var(--hub-text, #111827);\n      font-size: 0.85rem;\n      transition: background .15s;\n    }\n    .btn:hover:not(:disabled) { background: var(--hub-bg, #f9fafb); }\n    .btn:disabled { opacity: .5; cursor: default; }\n\n    .btn-primary {\n      background: var(--hub-primary, #6366f1);\n      color: var(--hub-primary-fg, #fff);\n      border-color: transparent;\n    }\n    .btn-primary:hover:not(:disabled) { background: var(--hub-primary-hover, #4f46e5); }\n\n    .btn-log {\n      flex: 1;\n      font-weight: 600;\n      background: var(--hub-primary, #6366f1);\n      color: var(--hub-primary-fg, #fff);\n      border-color: transparent;\n    }\n    .btn-log:hover:not(:disabled) { background: var(--hub-primary-hover, #4f46e5); }\n    .btn-log.done {\n      background: #dcfce7;\n      color: #15803d;\n      border-color: #86efac;\n    }\n    .btn-log.done:hover:not(:disabled) { background: #bbf7d0; }\n\n    .btn-icon {\n      padding: 6px 10px;\n      font-size: 1rem;\n      border-radius: var(--hub-radius, 6px);\n      border: 1px solid var(--hub-border, #e5e7eb);\n      background: var(--hub-surface, #fff);\n    }\n    .btn-danger { color: #dc2626; border-color: #fecaca; }\n    .btn-danger:hover:not(:disabled) { background: #fef2f2; }\n\n    .empty-state {\n      text-align: center;\n      padding: 48px 20px;\n      color: var(--hub-text-muted, #6b7280);\n    }\n    .empty-state p { margin-top: 8px; font-size: 0.9rem; }\n\n    /* Modal */\n    .modal-backdrop {\n      position: fixed; inset: 0;\n      background: rgba(0,0,0,.4);\n      display: flex; align-items: center; justify-content: center;\n      z-index: 1000;\n      padding: 16px;\n    }\n    .modal {\n      background: var(--hub-surface, #fff);\n      border-radius: var(--hub-radius, 8px);\n      padding: 24px;\n      width: 100%;\n      max-width: 440px;\n      box-shadow: 0 20px 60px rgba(0,0,0,.2);\n    }\n    .modal h2 { font-size: 1.1rem; font-weight: 700; margin-bottom: 16px; }\n    .modal-body { display: flex; flex-direction: column; gap: 14px; }\n    .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 20px; }\n\n    .form-group { display: flex; flex-direction: column; gap: 5px; }\n    label { font-size: 0.85rem; font-weight: 500; }\n    input[type=\"text\"], select, textarea {\n      padding: 8px 10px;\n      border: 1px solid var(--hub-border, #e5e7eb);\n      border-radius: var(--hub-radius, 6px);\n      font-family: inherit;\n      font-size: 0.9rem;\n      background: var(--hub-bg, #f9fafb);\n      color: var(--hub-text, #111827);\n    }\n    input[type=\"text\"]:focus, select:focus { outline: 2px solid var(--hub-primary, #6366f1); outline-offset: 1px; }\n\n    .emoji-row {\n      display: flex;\n      gap: 8px;\n      flex-wrap: wrap;\n    }\n    .emoji-opt {\n      font-size: 1.5rem;\n      width: 44px; height: 44px;\n      border-radius: 8px;\n      border: 2px solid var(--hub-border, #e5e7eb);\n      background: var(--hub-bg, #f9fafb);\n      cursor: pointer;\n      display: flex; align-items: center; justify-content: center;\n      transition: border-color .12s;\n    }\n    .emoji-opt.selected { border-color: var(--hub-primary, #6366f1); background: var(--hub-surface, #fff); }\n\n    .toggle-row {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 8px;\n    }\n    .toggle-label { font-size: 0.9rem; }\n    .toggle-desc { font-size: 0.78rem; color: var(--hub-text-muted, #6b7280); margin-top: 2px; }\n    .toggle {\n      position: relative;\n      display: inline-flex;\n      align-items: center;\n      flex-shrink: 0;\n    }\n    .toggle input { opacity: 0; width: 0; height: 0; position: absolute; }\n    .toggle-track {\n      width: 40px; height: 22px;\n      border-radius: 99px;\n      background: var(--hub-border, #e5e7eb);\n      transition: background .15s;\n      cursor: pointer;\n      position: relative;\n    }\n    .toggle input:checked + .toggle-track { background: var(--hub-primary, #6366f1); }\n    .toggle-track::after {\n      content: \"\";\n      position: absolute;\n      top: 3px; left: 3px;\n      width: 16px; height: 16px;\n      border-radius: 50%;\n      background: #fff;\n      transition: transform .15s;\n    }\n    .toggle input:checked + .toggle-track::after { transform: translateX(18px); }\n\n    .status { text-align: center; padding: 8px; color: var(--hub-text-muted, #6b7280); font-size: 0.85rem; }\n\n    /* Streak detail / log history */\n    .log-history { margin-top: 8px; }\n    .log-history h3 { font-size: 0.85rem; font-weight: 600; color: var(--hub-text-muted, #6b7280); text-transform: uppercase; letter-spacing: .04em; margin-bottom: 8px; }\n    .log-list { display: flex; flex-direction: column; gap: 4px; }\n    .log-item { font-size: 0.85rem; color: var(--hub-text-muted, #6b7280); padding: 4px 0; border-bottom: 1px solid var(--hub-border, #e5e7eb); }\n    .log-item:last-child { border-bottom: none; }\n  </style>\n</head>\n<body>\n<div class=\"app-header\">\n  <h1>🔥 Streaks</h1>\n  <span id=\"status-msg\" class=\"status\" style=\"flex:1\"></span>\n</div>\n\n<div class=\"tabs\">\n  <button class=\"tab-btn active\" onclick=\"switchTab('mine')\">Mine</button>\n  <button class=\"tab-btn\" onclick=\"switchTab('family')\">Family</button>\n</div>\n\n<div id=\"tab-mine\" class=\"tab-panel active\">\n  <div class=\"section-actions\">\n    <button class=\"btn btn-primary\" onclick=\"openCreateModal()\">+ New Streak</button>\n  </div>\n  <div id=\"mine-grid\" class=\"streak-grid\"></div>\n  <div id=\"mine-empty\" class=\"empty-state\" style=\"display:none\">\n    <div style=\"font-size:2.5rem\">🔥</div>\n    <p>No streaks yet. Create one to get started!</p>\n  </div>\n</div>\n\n<div id=\"tab-family\" class=\"tab-panel\">\n  <div id=\"family-grid\" class=\"streak-grid\"></div>\n  <div id=\"family-empty\" class=\"empty-state\" style=\"display:none\">\n    <div style=\"font-size:2.5rem\">👨‍👩‍👧</div>\n    <p>No shared or group streaks yet.</p>\n  </div>\n</div>\n\n<script type=\"module\">\nimport { computeStreaks, todayDate, milestoneReached } from \"./logic.js\";\nimport { esc, isAdult, hubConfirm, memberColor, initial } from \"/hub-sdk.js\";\n\nconst CONTEXT     = window.__CONTEXT_URL     ?? \"\";\nconst DB          = window.__DB_URL          ?? \"\";\nconst EVENTS_URL  = window.__EVENTS_URL      ?? \"/api/events\";\nconst APP_ID      = window.__APP_ID          ?? \"streaks\";\nconst ME          = window.__CURRENT_MEMBER  ?? null;\n\nlet members = [];\nlet allStreaks = [];   // raw rows from DB\nlet logMap   = {};     // streakId -> [YYYY-MM-DD, ...]\nlet modalEl  = null;\nlet selectedEmoji = \"🔥\";\n\n// ── DB helper ───────────────────────────────────────────────────────────────\n\nasync function db(sql, params = []) {\n  if (!DB) return { rows: [] };\n  const res = await fetch(DB, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ sql, params }),\n  });\n  return res.json();\n}\n\n// ── Init ────────────────────────────────────────────────────────────────────\n\n(async () => {\n  await loadMembers();\n  await Promise.all([loadStreaks(), loadLogs()]);\n  render();\n})();\n\nasync function loadMembers() {\n  if (!CONTEXT) {\n    members = [\n      { id: \"demo-1\", name: \"Alex\", role: \"adult\" },\n      { id: \"demo-2\", name: \"Sam\",  role: \"adult\" },\n      { id: \"demo-3\", name: \"Mia\",  role: \"child\" },\n    ];\n    return;\n  }\n  try {\n    const res = await fetch(`${CONTEXT}?keys=family.members`);\n    members = ((await res.json())[\"family.members\"]) ?? [];\n  } catch { members = []; }\n}\n\nasync function loadStreaks() {\n  if (!DB) {\n    allStreaks = demoStreaks();\n    return;\n  }\n  const r = await db(`SELECT id, owner_id, title, emoji, visibility, is_group, created_at, archived_at FROM streaks WHERE archived_at IS NULL ORDER BY created_at ASC`);\n  allStreaks = r.rows ?? [];\n}\n\nasync function loadLogs() {\n  if (!DB) {\n    logMap = demoLogs();\n    return;\n  }\n  // Load all logs for the last 400 days (enough for best streak calculation)\n  const cutoff = new Date();\n  cutoff.setDate(cutoff.getDate() - 400);\n  const since = cutoff.toISOString().slice(0, 10);\n  const r = await db(\n    `SELECT streak_id, logged_date FROM streak_logs WHERE logged_date >= ? ORDER BY logged_date ASC`,\n    [since]\n  );\n  logMap = {};\n  for (const row of (r.rows ?? [])) {\n    if (!logMap[row.streak_id]) logMap[row.streak_id] = [];\n    logMap[row.streak_id].push(row.logged_date);\n  }\n}\n\n// ── Visibility filter ────────────────────────────────────────────────────────\n\nfunction canSee(streak) {\n  // Owner always sees their own streaks\n  if (streak.owner_id === ME?.id) return true;\n  // Group streaks follow visibility too\n  const vis = streak.visibility;\n  if (vis === \"private\") return false;\n  if (vis === \"adults\") return isAdult(ME, members);\n  return true; // 'everyone'\n}\n\n// ── Render ───────────────────────────────────────────────────────────────────\n\nfunction render() {\n  const visibleStreaks = allStreaks.filter(canSee);\n  const mine   = visibleStreaks.filter(s => s.owner_id === ME?.id || (!ME && true));\n  const family = visibleStreaks.filter(s => s.is_group || s.owner_id !== ME?.id);\n\n  renderGrid(\"mine-grid\",   \"mine-empty\",   mine,   true);\n  renderGrid(\"family-grid\", \"family-empty\", family, false);\n}\n\nfunction renderGrid(gridId, emptyId, streaks, isMine) {\n  const grid  = document.getElementById(gridId);\n  const empty = document.getElementById(emptyId);\n  if (!streaks.length) {\n    grid.innerHTML = \"\";\n    empty.style.display = \"\";\n    return;\n  }\n  empty.style.display = \"none\";\n  grid.innerHTML = streaks.map(s => streakCard(s, isMine)).join(\"\");\n}\n\nfunction streakCard(s, showManage) {\n  const logs    = logMap[s.id] ?? [];\n  const { current, best, loggedToday: done } = computeStreaks(logs);\n  const canLog  = s.is_group || s.owner_id === ME?.id;\n  const isOwner = s.owner_id === ME?.id;\n\n  const owner = members.find(m => m.id === s.owner_id);\n  const ownerName = owner ? esc(owner.name) : \"\";\n\n  const visLabel = s.visibility === \"private\"\n    ? `<span class=\"badge badge-private\">🔒 Private</span>`\n    : s.visibility === \"adults\"\n      ? `<span class=\"badge badge-adults\">👤 Adults</span>`\n      : `<span class=\"badge badge-everyone\">🌍 Everyone</span>`;\n\n  const groupBadge = s.is_group\n    ? `<span class=\"badge badge-group\">👥 Group</span>`\n    : \"\";\n\n  return `\n    <div class=\"streak-card${done ? \" logged\" : \"\"}\" id=\"card-${esc(s.id)}\">\n      <div class=\"streak-top\">\n        <div class=\"streak-emoji\">${esc(s.emoji)}</div>\n        <div class=\"streak-info\">\n          <div class=\"streak-title\">${esc(s.title)}</div>\n          ${!showManage && ownerName ? `<div class=\"streak-owner\">${ownerName}</div>` : \"\"}\n        </div>\n      </div>\n      <div class=\"streak-counts\">\n        <div class=\"count-block\">\n          <div class=\"count-val count-fire\">${current}</div>\n          <div class=\"count-label\">🔥 Current</div>\n        </div>\n        <div class=\"count-block\">\n          <div class=\"count-val count-best\">${best}</div>\n          <div class=\"count-label\">⭐ Best</div>\n        </div>\n      </div>\n      <div class=\"streak-badges\">\n        ${showManage ? visLabel : \"\"}\n        ${groupBadge}\n      </div>\n      <div class=\"streak-actions\">\n        ${canLog ? `\n          <button class=\"btn btn-log${done ? \" done\" : \"\"}\"\n                  onclick=\"window.toggleLog('${esc(s.id)}', ${done})\"\n                  ${done ? \"\" : \"\"}>\n            ${done ? \"✓ Logged today\" : \"Log today\"}\n          </button>\n        ` : \"\"}\n        ${showManage && isOwner ? `\n          <button class=\"btn btn-icon\" title=\"Edit\" onclick=\"window.openEditModal('${esc(s.id)}')\">✏️</button>\n          <button class=\"btn btn-icon btn-danger\" title=\"Archive\" onclick=\"window.archiveStreak('${esc(s.id)}')\">🗑</button>\n        ` : \"\"}\n      </div>\n    </div>\n  `;\n}\n\n// ── Log / Unlog ──────────────────────────────────────────────────────────────\n\nwindow.toggleLog = async function(streakId, alreadyDone) {\n  if (!ME) { setStatus(\"Sign in to log streaks.\"); return; }\n  const today = todayDate();\n\n  if (alreadyDone) {\n    if (!await hubConfirm({ message: \"Undo today's log?\", confirmLabel: \"Undo\", destructive: true })) return;\n    await db(\n      `DELETE FROM streak_logs WHERE streak_id = ? AND logged_date = ? AND logged_by = ?`,\n      [streakId, today, ME.id]\n    );\n    if (logMap[streakId]) {\n      logMap[streakId] = logMap[streakId].filter(d => d !== today);\n    }\n  } else {\n    const id = crypto.randomUUID();\n    try {\n      await db(\n        `INSERT INTO streak_logs (id, streak_id, logged_by, logged_date, created_at) VALUES (?, ?, ?, ?, ?)`,\n        [id, streakId, ME.id, today, new Date().toISOString()]\n      );\n      if (!logMap[streakId]) logMap[streakId] = [];\n      logMap[streakId].push(today);\n\n      // Check for milestone\n      const { current } = computeStreaks(logMap[streakId]);\n      if (milestoneReached(current)) {\n        const streak = allStreaks.find(s => s.id === streakId);\n        await publishMilestone(streak, current);\n      }\n    } catch (e) {\n      setStatus(\"Already logged today.\");\n      return;\n    }\n  }\n  render();\n};\n\nasync function publishMilestone(streak, days) {\n  if (!streak) return;\n  await fetch(EVENTS_URL, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({\n      source_app_id: APP_ID,\n      type: \"streak.milestone\",\n      subject_id: ME?.id,\n      payload: { streak_id: streak.id, title: streak.title, emoji: streak.emoji, days },\n    }),\n  }).catch(() => {});\n}\n\n// ── Create / Edit Modal ──────────────────────────────────────────────────────\n\nconst EMOJI_OPTS = [\"🔥\",\"💪\",\"🏃\",\"📚\",\"🥗\",\"💧\",\"🧘\",\"🎯\",\"🎸\",\"✍️\",\"🛌\",\"🚴\",\"🌱\",\"🧹\",\"💊\"];\n\nwindow.openCreateModal = function() {\n  selectedEmoji = \"🔥\";\n  openModal(streakFormHtml(null));\n};\n\nwindow.openEditModal = function(streakId) {\n  const s = allStreaks.find(x => x.id === streakId);\n  if (!s) return;\n  selectedEmoji = s.emoji;\n  openModal(streakFormHtml(s));\n};\n\nfunction streakFormHtml(existing) {\n  const isEdit = !!existing;\n  const emojiButtons = EMOJI_OPTS.map(e =>\n    `<button type=\"button\" class=\"emoji-opt${e === selectedEmoji ? \" selected\" : \"\"}\" onclick=\"window.selectEmoji('${e}')\">${e}</button>`\n  ).join(\"\");\n\n  return `\n    <h2>${isEdit ? \"Edit Streak\" : \"New Streak\"}</h2>\n    <div class=\"modal-body\">\n      <div class=\"form-group\">\n        <label for=\"f-title\">Name</label>\n        <input type=\"text\" id=\"f-title\" placeholder=\"e.g. Morning run\" maxlength=\"60\" value=\"${isEdit ? esc(existing.title) : \"\"}\" />\n      </div>\n      <div class=\"form-group\">\n        <label>Emoji</label>\n        <div class=\"emoji-row\" id=\"emoji-row\">${emojiButtons}</div>\n      </div>\n      <div class=\"form-group\">\n        <label for=\"f-vis\">Visibility</label>\n        <select id=\"f-vis\">\n          <option value=\"private\"  ${!isEdit || existing.visibility===\"private\"  ? \"selected\" : \"\"}>🔒 Private — only me</option>\n          <option value=\"adults\"   ${isEdit && existing.visibility===\"adults\"    ? \"selected\" : \"\"}>👤 Adults only</option>\n          <option value=\"everyone\" ${isEdit && existing.visibility===\"everyone\"  ? \"selected\" : \"\"}>🌍 Everyone</option>\n        </select>\n      </div>\n      <div class=\"toggle-row\">\n        <div>\n          <div class=\"toggle-label\">Group streak</div>\n          <div class=\"toggle-desc\">Anyone who can see this streak can also log it</div>\n        </div>\n        <label class=\"toggle\">\n          <input type=\"checkbox\" id=\"f-group\" ${isEdit && existing.is_group ? \"checked\" : \"\"} />\n          <span class=\"toggle-track\"></span>\n        </label>\n      </div>\n    </div>\n    <div class=\"modal-actions\">\n      <button class=\"btn\" onclick=\"closeModal()\">Cancel</button>\n      <button class=\"btn btn-primary\" onclick=\"window.saveStreak('${isEdit ? esc(existing.id) : \"\"}')\">\n        ${isEdit ? \"Save\" : \"Create\"}\n      </button>\n    </div>\n  `;\n}\n\nwindow.selectEmoji = function(emoji) {\n  selectedEmoji = emoji;\n  document.querySelectorAll(\".emoji-opt\").forEach(btn => {\n    btn.classList.toggle(\"selected\", btn.textContent === emoji);\n  });\n};\n\nwindow.saveStreak = async function(existingId) {\n  const title = document.getElementById(\"f-title\").value.trim();\n  if (!title) { document.getElementById(\"f-title\").focus(); return; }\n  const visibility = document.getElementById(\"f-vis\").value;\n  const isGroup    = document.getElementById(\"f-group\").checked ? 1 : 0;\n  const emoji      = selectedEmoji;\n\n  const btn = modalEl?.querySelector(\".modal-actions .btn-primary\");\n  if (btn) { btn.disabled = true; btn.textContent = \"Saving…\"; }\n\n  try {\n    if (existingId) {\n      await db(\n        `UPDATE streaks SET title=?, emoji=?, visibility=?, is_group=? WHERE id=?`,\n        [title, emoji, visibility, isGroup, existingId]\n      );\n      const s = allStreaks.find(x => x.id === existingId);\n      if (s) Object.assign(s, { title, emoji, visibility, is_group: isGroup });\n    } else {\n      if (!ME) { setStatus(\"Sign in to create streaks.\"); return; }\n      const id = crypto.randomUUID();\n      const now = new Date().toISOString();\n      await db(\n        `INSERT INTO streaks (id, owner_id, title, emoji, visibility, is_group, created_at) VALUES (?, ?, ?, ?, ?, ?, ?)`,\n        [id, ME.id, title, emoji, visibility, isGroup, now]\n      );\n      allStreaks.push({ id, owner_id: ME.id, title, emoji, visibility, is_group: isGroup, created_at: now, archived_at: null });\n    }\n    closeModal();\n    render();\n  } catch (e) {\n    if (btn) { btn.disabled = false; btn.textContent = existingId ? \"Save\" : \"Create\"; }\n    throw e;\n  }\n};\n\n// ── Archive ──────────────────────────────────────────────────────────────────\n\nwindow.archiveStreak = async function(streakId) {\n  const s = allStreaks.find(x => x.id === streakId);\n  if (!s) return;\n  if (!await hubConfirm({\n    message: `Archive \"${s.title}\"?`,\n    description: \"It will no longer appear in your list. Your log history is preserved.\",\n    confirmLabel: \"Archive\",\n    destructive: true,\n  })) return;\n\n  await db(`UPDATE streaks SET archived_at=? WHERE id=?`, [new Date().toISOString(), streakId]);\n  allStreaks = allStreaks.filter(x => x.id !== streakId);\n  render();\n};\n\n// ── Modal helpers ─────────────────────────────────────────────────────────────\n\nfunction openModal(html) {\n  closeModal();\n  modalEl = document.createElement(\"div\");\n  modalEl.className = \"modal-backdrop\";\n  modalEl.innerHTML = `<div class=\"modal\">${html}</div>`;\n  modalEl.addEventListener(\"click\", e => { if (e.target === modalEl) closeModal(); });\n  document.body.appendChild(modalEl);\n}\nwindow.closeModal = function() { modalEl?.remove(); modalEl = null; };\n\nfunction setStatus(msg) {\n  const el = document.getElementById(\"status-msg\");\n  if (!el) return;\n  el.textContent = msg;\n  setTimeout(() => { el.textContent = \"\"; }, 3000);\n}\n\n// ── Tab switching ────────────────────────────────────────────────────────────\n\nwindow.switchTab = function(name) {\n  document.querySelectorAll(\".tab-btn\").forEach((btn, i) => {\n    btn.classList.toggle(\"active\", btn.getAttribute(\"onclick\").includes(`'${name}'`));\n  });\n  document.getElementById(\"tab-mine\").classList.toggle(\"active\", name === \"mine\");\n  document.getElementById(\"tab-family\").classList.toggle(\"active\", name === \"family\");\n};\n\n// ── Demo data ─────────────────────────────────────────────────────────────────\n\nfunction demoStreaks() {\n  return [\n    { id: \"d1\", owner_id: \"demo-1\", title: \"Morning run\",     emoji: \"🏃\", visibility: \"everyone\", is_group: 0, created_at: \"2025-01-01\", archived_at: null },\n    { id: \"d2\", owner_id: \"demo-1\", title: \"Read 20 min\",     emoji: \"📚\", visibility: \"private\",  is_group: 0, created_at: \"2025-01-01\", archived_at: null },\n    { id: \"d3\", owner_id: \"demo-2\", title: \"Drink 8 glasses\", emoji: \"💧\", visibility: \"everyone\", is_group: 0, created_at: \"2025-01-01\", archived_at: null },\n    { id: \"d4\", owner_id: \"demo-1\", title: \"Family walk\",     emoji: \"🌳\", visibility: \"everyone\", is_group: 1, created_at: \"2025-01-01\", archived_at: null },\n  ];\n}\n\nfunction demoLogs() {\n  const today = todayDate();\n  const offset = n => {\n    const d = new Date(today + \"T00:00:00\");\n    d.setDate(d.getDate() + n);\n    return d.toISOString().slice(0, 10);\n  };\n  return {\n    d1: [offset(-6), offset(-5), offset(-4), offset(-3), offset(-2), offset(-1), today],\n    d2: [offset(-14), offset(-13), offset(-12), offset(-3), offset(-2), offset(-1)],\n    d3: [offset(-2), offset(-1)],\n    d4: [offset(-1), today],\n  };\n}\n</script>\n</body>\n</html>\n",
    "inserts/log_streak.sql": "INSERT INTO streak_logs (\n  id,\n  household_id,\n  streak_id,\n  logged_by,\n  logged_date,\n  created_at\n) VALUES (\n  gen_random_uuid()::text,\n  current_setting('app.household_id', true)::uuid,\n  $1,\n  'ai',\n  COALESCE($2, CURRENT_DATE::text),\n  NOW()::text\n)\nON CONFLICT (household_id, streak_id, logged_date) DO NOTHING\n",
    "logic.js": "/**\n * Returns today's date as YYYY-MM-DD in local time.\n */\nexport function todayDate() {\n  const d = new Date();\n  const y = d.getFullYear();\n  const m = String(d.getMonth() + 1).padStart(2, \"0\");\n  const day = String(d.getDate()).padStart(2, \"0\");\n  return `${y}-${m}-${day}`;\n}\n\n/**\n * Returns yesterday's date as YYYY-MM-DD in local time.\n */\nexport function yesterdayDate() {\n  const d = new Date();\n  d.setDate(d.getDate() - 1);\n  const y = d.getFullYear();\n  const m = String(d.getMonth() + 1).padStart(2, \"0\");\n  const day = String(d.getDate()).padStart(2, \"0\");\n  return `${y}-${m}-${day}`;\n}\n\n/**\n * Given an array of YYYY-MM-DD log dates, returns:\n *   { current, best, loggedToday }\n *\n * current: consecutive days ending today or yesterday (streak is alive if last log was yesterday)\n * best: longest consecutive run ever recorded\n * loggedToday: whether today's date appears in logDates\n */\nexport function computeStreaks(logDates) {\n  if (!logDates || logDates.length === 0) {\n    return { current: 0, best: 0, loggedToday: false };\n  }\n\n  const today = todayDate();\n  const yesterday = yesterdayDate();\n\n  // Deduplicate and sort ascending\n  const unique = [...new Set(logDates)].sort();\n  const loggedToday = unique.includes(today);\n\n  // Walk sorted dates to find all consecutive runs\n  let best = 1;\n  let runLen = 1;\n  const runs = []; // each { end, length }\n\n  for (let i = 1; i < unique.length; i++) {\n    const prev = new Date(unique[i - 1] + \"T00:00:00\");\n    const curr = new Date(unique[i] + \"T00:00:00\");\n    const diffDays = Math.round((curr - prev) / 86400000);\n    if (diffDays === 1) {\n      runLen++;\n    } else {\n      runs.push({ end: unique[i - 1], length: runLen });\n      if (runLen > best) best = runLen;\n      runLen = 1;\n    }\n  }\n  runs.push({ end: unique[unique.length - 1], length: runLen });\n  if (runLen > best) best = runLen;\n\n  // Current streak: the run whose end is today or yesterday\n  const lastRun = runs[runs.length - 1];\n  let current = 0;\n  if (lastRun.end === today || lastRun.end === yesterday) {\n    current = lastRun.length;\n  }\n\n  return { current, best, loggedToday };\n}\n\n/**\n * Returns true if today's date appears in logDates.\n */\nexport function loggedToday(logDates) {\n  return computeStreaks(logDates).loggedToday;\n}\n\n/**\n * Returns milestone thresholds crossed by going from (days-1) to days.\n * Used to decide whether to publish a streak.milestone event.\n */\nexport const MILESTONES = [3, 7, 14, 30, 60, 100, 200, 365];\n\nexport function milestoneReached(days) {\n  return MILESTONES.includes(days);\n}\n",
    "queries/active_streaks.sql": "SELECT\n  s.id,\n  s.owner_id,\n  s.title,\n  s.emoji,\n  s.visibility,\n  s.is_group,\n  s.created_at,\n  COUNT(sl.id)   AS total_logs,\n  MAX(sl.logged_date) AS last_logged_date\nFROM streaks s\nLEFT JOIN streak_logs sl\n  ON sl.streak_id    = s.id\n  AND sl.household_id = s.household_id\nWHERE s.household_id = current_setting('app.household_id', true)::uuid\n  AND s.archived_at  IS NULL\n  AND s.visibility   IN ('adults', 'everyone')\nGROUP BY s.id, s.owner_id, s.title, s.emoji, s.visibility, s.is_group, s.created_at\nORDER BY last_logged_date DESC NULLS LAST, s.title\nLIMIT 100\n",
    "queries/todays_completions.sql": "SELECT\n  sl.id,\n  sl.streak_id,\n  sl.logged_by,\n  sl.logged_date,\n  s.title  AS streak_title,\n  s.emoji  AS streak_emoji\nFROM streak_logs sl\nJOIN streaks s\n  ON s.id           = sl.streak_id\n  AND s.household_id = sl.household_id\nWHERE sl.household_id = current_setting('app.household_id', true)::uuid\n  AND sl.logged_date  = CURRENT_DATE::text\n  AND s.archived_at   IS NULL\nORDER BY sl.created_at DESC\nLIMIT 100\n",
    "schemas/log_streak.json": "{\n  \"type\": \"array\",\n  \"items\": [\n    { \"type\": \"string\", \"minLength\": 1, \"description\": \"Streak ID (from active_streaks query)\" },\n    { \"type\": [\"string\", \"null\"], \"pattern\": \"^\\\\d{4}-\\\\d{2}-\\\\d{2}$\", \"description\": \"Date to log (YYYY-MM-DD) — omit or null for today\" }\n  ],\n  \"minItems\": 1,\n  \"maxItems\": 2\n}\n"
  }
}